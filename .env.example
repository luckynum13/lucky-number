# Lucky Number Bot — Environment Variables
# ==========================================
# ВАЖНО: Этот файл НЕ загружать на GitHub!
# Добавь эти переменные через Fly.io dashboard или командой:
#   fly secrets set BOT_TOKEN=xxxxx
#
# Локальный запуск: скопируй в .env и заполни значения

# ── ОБЯЗАТЕЛЬНЫЕ ──────────────────────────────────────

# Telegram Bot Token (от @BotFather)
BOT_TOKEN=your_bot_token_here

# URL твоего Fly.io приложения (после деплоя)
# Пример: https://lucky-number-bot.fly.dev
WEBHOOK_URL=https://lucky-number-bot.fly.dev

# Smart Glocal provider token (от @BotFather после подключения Smart Glocal)
SMART_GLOCAL_TOKEN=your_smart_glocal_token_here

# Секретный ключ для верификации Smart Glocal вебхуков
# Любая случайная строка, например: openssl rand -hex 32
WEBHOOK_SECRET=generate_random_string_here

# ── БАЗА ДАННЫХ ───────────────────────────────────────

# SQLite (для старта — простой вариант)
DATABASE_URL=sqlite+aiosqlite:///data/lucky.db

# PostgreSQL (для продакшена — раскомментировать когда готов)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/lucky_number

# ── МИНИ АПП ──────────────────────────────────────────

# URL твоего Mini App на GitHub Pages
# Пример: https://yourusername.github.io/lucky-number
MINI_APP_URL=https://yourusername.github.io/lucky-number
